# Copy to .env.local (local dev) and set the same var in Vercel → Project → Settings → Environment Variables.
# Monday API token: monday.com → avatar → Developers → My access tokens.
# NEVER commit the real token. It is read only on the server (route handler), never sent to the browser.
MONDAY_TOKEN=your_monday_api_token_here

# Your Clients board ID (already known, kept as an env var so nothing is hardcoded).
CLIENTS_BOARD_ID=5099721289
